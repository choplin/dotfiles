go_srcs := $(shell find . -type f -name "*.go" ! -path "./vendor/*", ! -path "./docker/*")

.PHONY: all
all: test

.PHONY: clean
clean:
	rm -rf out

.PHONY: test
test:
	go test --race $(shell glide nv)

.PHONY: lint
lint:
	gometalinter --vendor --tests $(shell glide nv)

.PHONY: bin
bin: out/log_forwarder
out/log_forwarder: $(go_srcs)
	go build -o out/log_forwarder

.PHONY: bin_linux
bin_linux: out/linux/log_forwarder
out/linux/log_forwarder: $(go_srcs)
	GOOS=linux GOARCH=amd64 go build -o out/linux/log_forwarder

.PHONY: run_kafka
run_kafka:
	DOCKER_HOST_ADDRESS=$(shell docker-machine ip) docker-compose up -d

.PHONY: stop_kafka
stop_kafka:
	docker-compose stop && docker-compose rm -f

.PHONY: benchmark_encoder
benchmark_encoder:
	go test -bench 'BenchmarkBiddingEncode'  -cpuprofile cpu.pprof ./parser

.PHONY: benchmark_parser
benchmark_parser:
	go test -bench 'BenchmarkBiddingParser'  -cpuprofile cpu.pprof ./parser


.PHONY: pprof
parser_pprof:
	go tool pprof parser.test cpu.pprof

bin_tmp:
	GOOS=linux GOARCH=amd64 go build -o out/linux/pipelinedb_cli ./pipelinedb

