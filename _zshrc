# lsとpsの設定 {{{
# ls: できるだけGNU lsを使う。
# ps: 自分関連のプロセスのみ表示。
case $(uname) in
    *BSD|Darwin)
        if [ -x "$(which gnuls)" ]; then
            alias ls="gnuls"
        fi
        alias ps="ps -fU$(whoami)"
        ;;
    SunOS)
        if [ -x "`which gls`" ]; then
            alias ls="gls"
        fi
        alias ps="ps -fl -u$(/usr/xpg4/bin/id -un)"
        ;;
    *)
        alias ps="ps -fU$(whoami) --forest"
        ;;
esac

case "${OSTYPE}" in
freebsd*|darwin*)
    alias ls="ls -v -F -G -w"
    ;;
linux*)
    alias ls="ls -v -F --color"
    ;;
esac

