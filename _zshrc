typeset -U fpath

fpath=($HOME/.zsh/functions(N-/)
       /usr/local/share/zsh-completions(N-/)
       $fpath)


# Source Prezto.
if [[ -s "${ZDOTDIR:-$HOME}/.zprezto/init.zsh" ]]; then
  source "${ZDOTDIR:-$HOME}/.zprezto/init.zsh"
fi

# Customize to your needs...

for f in fzf profile zplug util; do
    local file="$HOME/.zsh/custom/$f.zsh"
    if [ -f $file ];then
        source $file
    fi
done

if [ -f $HOME/.zshrc.local ]; then
    source $HOME/.zshrc.local
fi

export LD_LIBRARY_PATH=/Users/okuno/tmp/instantclient_11_2:$LD_LIBRARY_PATH
export DYLD_LIBRARY_PATH=/Users/okuno/tmp/instantclient_11_2:$DYLD_LIBRARY_PATH
export ORACLE_HOME=/Users/okuno/tmp/instantclient_11_2

#[ -f ~/.fzf.zsh ] && source ~/.fzf.zsh

test -e "${HOME}/.iterm2_shell_integration.zsh" && source "${HOME}/.iterm2_shell_integration.zsh"
