#!/bin/bash

PLUGIN_DIR="$CONFIG_DIR/plugins"

source "$PLUGIN_DIR/colors.sh"
source "$PLUGIN_DIR/icons.sh"

# Bar settings (transparent background for split layout)
sketchybar --bar \
    height=28 \
    color=0x00000000 \
    position=top \
    sticky=on \
    margin=8 \
    padding_left=8 \
    padding_right=8 \
    y_offset=2 \
    display=main

# Default item settings (no background on items)
sketchybar --default \
    background.drawing=off \
    icon.font="SF Pro:Semibold:14.0" \
    icon.color=$COLOR_TEXT \
    icon.padding_left=8 \
    icon.padding_right=4 \
    label.font="SF Pro:Medium:13.0" \
    label.color=$COLOR_TEXT \
    label.padding_left=4 \
    label.padding_right=8 \
    padding_left=0 \
    padding_right=0

# === Events ===
sketchybar --add event aerospace_workspace_change
sketchybar --add event timer_update

# === Left section ===
# Workspace name
sketchybar --add item workspace left \
    --subscribe workspace aerospace_workspace_change \
    --set workspace \
    icon.drawing=off \
    icon.padding_left=0 \
    icon.padding_right=0 \
    label.padding_left=12 \
    label.padding_right=12 \
    background.drawing=on \
    background.color=$COLOR_BG_PRIMARY \
    background.corner_radius=14 \
    background.padding_right=-20 \
    script="$PLUGIN_DIR/workspace.sh"

# App list items (pre-created, updated dynamically)
sketchybar --add item ws_app_0 left --set ws_app_0 drawing=off icon.drawing=off background.drawing=off \
    --add item ws_dot_0 left --set ws_dot_0 drawing=off icon.drawing=off label.drawing=off background.drawing=off \
    --add item ws_app_1 left --set ws_app_1 drawing=off icon.drawing=off background.drawing=off \
    --add item ws_dot_1 left --set ws_dot_1 drawing=off icon.drawing=off label.drawing=off background.drawing=off \
    --add item ws_app_2 left --set ws_app_2 drawing=off icon.drawing=off background.drawing=off \
    --add item ws_dot_2 left --set ws_dot_2 drawing=off icon.drawing=off label.drawing=off background.drawing=off \
    --add item ws_app_3 left --set ws_app_3 drawing=off icon.drawing=off background.drawing=off

# App list bracket
sketchybar --add bracket ws_apps_bracket ws_app_0 ws_dot_0 ws_app_1 ws_dot_1 ws_app_2 ws_dot_2 ws_app_3 \
    --set ws_apps_bracket \
    background.drawing=on \
    background.color=$COLOR_BAR \
    background.corner_radius=14 \
    background.height=28

# === Center section ===
# Current task (from Obsidian daily note)
sketchybar --add item task center \
    --subscribe task mouse.exited.global \
    --set task \
    icon="$ICON_WORKSPACE" \
    label="No tasks" \
    label.padding_right=8 \
    update_freq=60 \
    click_script="$PLUGIN_DIR/task.sh" \
    script="$PLUGIN_DIR/task_update.sh" \
    popup.background.color=$COLOR_BAR \
    popup.background.corner_radius=10 \
    popup.background.border_color=$COLOR_TEXT_DIM \
    popup.background.border_width=1

# Task popup menu items
sketchybar --add item task_menu_complete popup.task \
    --set task_menu_complete \
    icon="󰄬" \
    label="Complete" \
    click_script="$PLUGIN_DIR/task_action.sh complete"

sketchybar --add item task_menu_cancel popup.task \
    --set task_menu_cancel \
    icon="󰜺" \
    label="Cancel" \
    click_script="$PLUGIN_DIR/task_action.sh cancel"

sketchybar --add item task_menu_forward popup.task \
    --set task_menu_forward \
    icon="󰒊" \
    label="Forward" \
    click_script="$PLUGIN_DIR/task_action.sh forward"

sketchybar --add item task_menu_add popup.task \
    --set task_menu_add \
    icon="󰐕" \
    label="Add Task" \
    click_script="$PLUGIN_DIR/task_action.sh add"

sketchybar --add item task_menu_open popup.task \
    --set task_menu_open \
    icon="󰏋" \
    label="Open Obsidian" \
    click_script="$PLUGIN_DIR/task_action.sh open"

# Timer (pomodoro-based with selectable duration)
sketchybar --add item timer center \
    --subscribe timer timer_update mouse.exited.global \
    --set timer \
    icon="$ICON_POMODORO" \
    icon.color=$COLOR_TEXT_DIM \
    label="--:--" \
    label.width=50 \
    label.align=center \
    update_freq=0 \
    click_script="$PLUGIN_DIR/timer_click.sh" \
    script="$PLUGIN_DIR/timer_update.sh" \
    popup.background.color=$COLOR_BAR \
    popup.background.corner_radius=10 \
    popup.background.border_color=$COLOR_TEXT_DIM \
    popup.background.border_width=1

# Timer popup menu items (idle state)
sketchybar --add item timer_menu_25 popup.timer \
    --set timer_menu_25 \
    icon="󰔟" \
    label="25 min" \
    click_script="$PLUGIN_DIR/timer_action.sh 25"

sketchybar --add item timer_menu_5 popup.timer \
    --set timer_menu_5 \
    icon="󰔟" \
    label="5 min" \
    click_script="$PLUGIN_DIR/timer_action.sh 5"

sketchybar --add item timer_menu_1 popup.timer \
    --set timer_menu_1 \
    icon="󰔟" \
    label="1 min" \
    click_script="$PLUGIN_DIR/timer_action.sh 1"

# Timer popup menu items (running/paused/break state)
sketchybar --add item timer_menu_pause popup.timer \
    --set timer_menu_pause \
    icon="󰏤" \
    label="Pause" \
    drawing=off \
    click_script="$PLUGIN_DIR/timer_action.sh pause"

sketchybar --add item timer_menu_resume popup.timer \
    --set timer_menu_resume \
    icon="󰐊" \
    label="Resume" \
    drawing=off \
    click_script="$PLUGIN_DIR/timer_action.sh resume"

sketchybar --add item timer_menu_reset popup.timer \
    --set timer_menu_reset \
    icon="󰜉" \
    label="Reset" \
    drawing=off \
    click_script="$PLUGIN_DIR/timer_action.sh reset"

sketchybar --add item timer_menu_skip popup.timer \
    --set timer_menu_skip \
    icon="󰒭" \
    label="Skip Break" \
    drawing=off \
    click_script="$PLUGIN_DIR/timer_action.sh skip"

# Next calendar event
sketchybar --add item calendar center \
    --subscribe calendar mouse.exited.global \
    --set calendar \
    icon="$ICON_CALENDAR" \
    label="No events" \
    label.padding_right=12 \
    update_freq=60 \
    click_script="$PLUGIN_DIR/calendar.sh" \
    script="$PLUGIN_DIR/calendar_update.sh" \
    popup.background.color=$COLOR_BAR \
    popup.background.corner_radius=10 \
    popup.background.border_color=$COLOR_TEXT_DIM \
    popup.background.border_width=1

# Calendar popup menu items (max 5 events)
sketchybar --add item calendar_menu_0 popup.calendar \
    --set calendar_menu_0 icon="󰃭" label="" drawing=off
sketchybar --add item calendar_menu_1 popup.calendar \
    --set calendar_menu_1 icon="󰃭" label="" drawing=off
sketchybar --add item calendar_menu_2 popup.calendar \
    --set calendar_menu_2 icon="󰃭" label="" drawing=off
sketchybar --add item calendar_menu_3 popup.calendar \
    --set calendar_menu_3 icon="󰃭" label="" drawing=off
sketchybar --add item calendar_menu_4 popup.calendar \
    --set calendar_menu_4 icon="󰃭" label="" drawing=off

# Center bracket
sketchybar --add bracket center_bracket task timer calendar \
    --set center_bracket \
    background.drawing=on \
    background.color=$COLOR_BAR \
    background.corner_radius=14 \
    background.height=28

# === Right section ===
# Clock (rightmost)
sketchybar --add item clock right \
    --set clock \
    icon="$ICON_CLOCK" \
    icon.padding_left=12 \
    label.padding_right=12 \
    background.drawing=on \
    background.color=$COLOR_BG_PRIMARY \
    background.corner_radius=14 \
    background.padding_left=-20 \
    update_freq=60 \
    script="$PLUGIN_DIR/clock.sh" \
    click_script="$PLUGIN_DIR/clock_click.sh"

# Battery
sketchybar --add item battery right \
    --subscribe battery power_source_change system_woke \
    --set battery \
    icon="$ICON_BATTERY_100" \
    label.padding_right=28 \
    update_freq=300 \
    script="$PLUGIN_DIR/battery.sh" \
    click_script="$PLUGIN_DIR/battery_click.sh"

# Network (down/up as separate items for colored icons)
sketchybar --add item network_up right \
    --set network_up \
    icon="$ICON_NETWORK_UP" \
    icon.color="$PINK" \
    label="0K"

sketchybar --add item network_down right \
    --set network_down \
    icon="$ICON_NETWORK_DOWN" \
    icon.color="$CYAN" \
    label="0K"

# Memory
sketchybar --add item memory right \
    --set memory \
    icon="$ICON_MEMORY" \
    click_script="$PLUGIN_DIR/stats_click.sh"

# CPU (stats.sh updates cpu, memory, network_down, network_up together)
sketchybar --add item cpu right \
    --set cpu \
    icon="$ICON_CPU" \
    update_freq=5 \
    script="$PLUGIN_DIR/stats.sh" \
    click_script="$PLUGIN_DIR/stats_click.sh"

# YouTube Music / Now Playing (updated by media_stream.sh background process)
sketchybar --add item media right \
    --set media \
    icon="$ICON_MUSIC" \
    icon.font="Hack Nerd Font:Regular:16.0" \
    drawing=off

# Stats bracket (cpu, memory, network_down, network_up, battery)
sketchybar --add bracket stats_bracket cpu memory network_down network_up battery \
    --set stats_bracket \
    background.drawing=on \
    background.color=$COLOR_BAR \
    background.corner_radius=14 \
    background.height=28

sketchybar --update
