snippet include_guard
alias   inc_guard
prev_word '^'
abbr    #ifndef FOO #define FOO #endif
    #ifndef __`toupper( substitute( expand("%:t"), "\\.", "_", "g" ) )`__
    #define __`toupper( substitute( expand("%:t"), "\\.", "_", "g" ) )`__
    ${0}
    #endif /* __`toupper( substitute( expand("%:t"), "\\.", "_", "g" ) )`__ */
