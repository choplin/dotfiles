{
  "diff_view_style": "split",
  "agent_ui_font_size": 20.0,
  "agent_buffer_font_size": 20.0,
  "cli_default_open_behavior": "existing_window",
  "edit_predictions": {
    "provider": "copilot",
    "open_ai_compatible_api": {
      "model": "",
      "api_url": "",
    },
  },
  "agent_servers": {
    "cursor": {
      "type": "registry",
    },
    "codex-acp": {
      "type": "registry",
    },
    "glm-acp-agent": {
      "type": "registry",
    },
    "kimi": {
      "type": "registry",
    },
    "claude-acp": {
      "type": "custom",
      "command": "claude-agent-acp-direnv",
      "default_config_options": {
        "model": "claude-fable-5[1m]",
        "mode": "auto",
      },
    },
  },
  "outline_panel": {
    "dock": "right",
  },
  "collaboration_panel": {
    "dock": "right",
  },
  "agent": {
    "inline_assistant_model": {
      "provider": "copilot_chat",
      "model": "claude-sonnet-4.6",
      "enable_thinking": false,
    },
    "single_file_review": true,
    "notify_when_agent_waiting": "primary_screen",
    "default_profile": "ask",
    "default_model": {
      "provider": "openai-subscribed",
      "model": "gpt-5.5",
      "enable_thinking": false,
    },
    "commit_message_instructions": "Generate a git commit message following the Conventional Commits specification. The first line must be a conventional commit subject line with a required type (e.g. 'feat: add login feature'). The scope is required if the scope of the change is clear and limited to a single area; omit the scope if it spans multiple areas or is unclear (e.g. 'feat(auth): add login feature' vs 'feat: add login feature'). Write the subject verb in past tense (e.g. 'added', 'fixed', 'updated'). The second line must be blank. From the third line onward, if the purpose, background, motivation, or context of the change is clear, add a body describing them in detail. Otherwise, omit the body.",

    "commit_message_model": {
      "provider": "openai-subscribed",
      "model": "gpt-5.5",
    },
    "play_sound_when_agent_done": "always",
    "dock": "left",
    "favorite_models": [],
    "model_parameters": [],
  },
  "git_panel": {
    "tree_view": true,
    "dock": "right",
  },
  "icon_theme": "Catppuccin Mocha",
  "theme": "Tokyo Night",
  "buffer_font_family": "UDEV Gothic 35NF",
  "ui_font_size": 18,
  "buffer_font_size": 18,
  "buffer_line_height": { "custom": 1.5 },
  "terminal": {
    "font_size": 18.0,
    "font_family": "UDEV Gothic NF",
    "bell": "system",
  },
  "preview": {
    "theme": "One Dark",
  },
  "bottom_dock_layout": "left_aligned",
  "tab_bar": {
    "show": true,
  },
  "tabs": {
    "file_icons": true,
    "git_status": true,
  },
  "indent_guides": {
    "coloring": "indent_aware",
  },
  "inlay_hints": {
    "enabled": true,
  },
  "project_panel": {
    "hide_hidden": false,
    "hide_gitignore": false,
    "dock": "right",
    "auto_fold_dirs": true,
  },
  "preview_tabs": {
    "enable_keep_preview_on_code_navigation": true,
    "enable_preview_from_file_finder": true,
  },
  "soft_wrap": "editor_width",
  "always_treat_brackets_as_autoclosed": true,
  "vim_mode": true,
  "vim": {
    "use_smartcase_find": true,
  },
  "languages": {
    "Java": {
      "tab_size": 2,
    },
  },
  "node": {
    "ignore_system_version": true,
  },
  "load_direnv": "shell_hook",
  "context_servers": {
    "linear": {
      "command": "npx",
      "args": ["-y", "mcp-remote", "https://mcp.linear.app/mcp"],
      "env": {},
    },
  },
}
