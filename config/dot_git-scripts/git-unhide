#!/bin/bash
# Remove --assume-unchanged flag and untrack specified files from index

set -euo pipefail

usage() {
  cat <<EOF
Usage: git unhide <file>...

Remove --skip-worktree flag and untrack specified files from index.

Options:
  -h, --help    Show this help message
EOF
}

# Show help if requested
if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  usage
  exit 0
fi

# Require at least one file argument
if [[ $# -eq 0 ]]; then
  echo "Error: No files specified" >&2
  usage >&2
  exit 1
fi

# Process each file
for file in "$@"; do
  git update-index --no-skip-worktree "$file"
  git rm --cached "$file"
done

echo "Specified files are now fully untracked from index"
