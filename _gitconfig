[user]
  name = Akihiro Okuno
  email = choplin.choplin@gmail.com

[color]
  ui = auto

[push]
  default = tracking

[pull]
  rebase = true

[branch]
  autosetuprebase = always

[merge]
  ff = false

[core]
  autocrlf = input
  pager = less
  editor = command vim
  excludesfile = /home/okuno/.gitignore_global

[alias]
  alias = !git config --list | grep 'alias\\.' | sed 's/alias\\.\\([^=]*\\)=\\(.*\\)/\\1\\\t => \\2/' | sort

  s = status --short --branch
  st = status
  sh = show
  co = checkout
  br = branch

  ranking = shortlog -s -n --no-merges
  logg = log --stat --pretty=format:'%Cblue%h %Cgreen%ar %Cred%an %Creset%s %Cred%d'
  l = log --graph -n 20 --pretty=format:'%C(yellow)%h%C(cyan)%d%Creset %s %C(green)- %an, %cr%Creset'

  # logをtree表示
  log-graph = log --graph --date=short --pretty=format:'%Cgreen%h %cd %Cblue%cn %Creset%s'

  log-short =  log --pretty=\"format:%ad %h (%an): %s\" --date=short

  # diff関連
  dm = diff master           # masterとのdiff
  dw = diff --color-words    # 単語単位でいろつけてdiff
  dc = diff --cached         # addされているものとのdiff

  # grep関連
  gr = grep
  gn = grep -n

  # cancel
  cancel = !git commit -a -m 'Temporary commit for cancel' && git reset --hard HEAD~

  ignore = !([ ! -e .gitignore ] && touch .gitignore) | echo $1 >> .gitignore
  info = remote show origin

  fixup = commit --amend --no-edit

  stash-pr = !sh -c \"git fetch origin pull-requests/${1}/from:pr/${1}\" -
  github-pr = !sh -c \"git fetch origin pull/${1}/head:pr/${1}\" -

  pbcopy = !printf "$1" | pbcopy

  user-guess = !sh -c '~/.git-scripts/user-guess.sh'

  delete-merged-branches = !git branch --merged | grep -vE '^\\*|master$|develop$' | xargs -I % git branch -d %

[merge]
  tool = gvimdiff3

[tig "bind"]
  generic = g move-first-line
  generic = G move-last-line
  main = C !@git pbcopy %(commit)

[mergetool "gvimdiff3"]
  cmd = gvim -f -d -c \"wincmd J\" \"$MERGED\" \"$LOCAL\" \"$BASE\" \"$REMOTE\"

[mergetool "vimdiff3"]
  cmd = vim -f -d -c \"wincmd J\" \"$MERGED\" \"$LOCAL\" \"$BASE\" \"$REMOTE\"

[mergetool "sourcetree"]
  cmd = /Applications/SourceTree.app/Contents/Resources/opendiff-w.sh \"$LOCAL\" \"$REMOTE\" -ancestor \"$BASE\" -merge \"$MERGED\"
  trustExitCode = true

[http]
  sslVerify = true

[github]
  user = choplin

[difftool "sourcetree"]
  cmd = opendiff \"$LOCAL\" \"$REMOTE\"
  path = 

[ghi]
  token = !security find-internet-password -a choplin -s github.com -l 'ghi token' -w

[filter "lfs"]
  clean = git-lfs clean %f
  smudge = git-lfs smudge %f
  required = true

[include]
  path = .gitconfig.local

[http "https://gopkg.in"]
  followRedirects = true

