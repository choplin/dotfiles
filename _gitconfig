[user]
  name = choplin
  email = choplin.choplin@gmail.com

[color]
  ui = auto

[push]
  default = tracking

[pull]
  rebase = true

[branch]
  autosetuprebase = always

[merge]
  ff = false

[core]
	excludesfile = /Users/okuno/.gitignore
  autocrlf = input
  pager = lv -c
  editor = vim #/usr/bin/vim

[alias]
  alias = !git config --list | grep 'alias\\.' | sed 's/alias\\.\\([^=]*\\)=\\(.*\\)/\\1\\\t => \\2/' | sort

  s = status --short --branch
  st = status
  sh = show
  so = remote show origin
  ft = fetch
  up = pull --rebase       # pull rebase
  rbm = rebase master      # masterへのrebaseはよく使うのでalias
  ad = add
  ci = commit -a           # modifiedなファイルを全てstageへ
  cam = commit -a --amend  # 直前のcommitを修正
  co = checkout
  su = submodule update

  # branch関連
  br = branch
  ba = branch -a           # originも含めた全てのbranchを表示
  bm = branch --merged     # merge済みのbranchを表示
  bn = branch --no-merged  # mergeしてないbranchを表示

  # log関連
  wc = whatchanged         # logに変更されたファイルも一緒に出す
  ls = log --stat          # logに変更されたファイルも一緒に出す
  lp = log -p              # diffも一緒に出す
  la = log --pretty=\"format:%ad %h (%an): %s\" --date=short  # ざっくりログ出す
  lr = log origin          # originのlog
  oneline = log --pretty=oneline
  ranking = shortlog -s -n --no-merges
  logg = log --stat --pretty=format:'%Cblue%h %Cgreen%ar %Cred%an %Creset%s %Cred%d'
  #l = log --graph -n 20 --pretty=format:'%C(yellow)%h%C(cyan)%d%Creset %s %C(green)- %an, %cr%Creset'
  #ll = log --stat --abbrev-commit
  #ln = log --graph -n 20 --pretty=format:'%C(yellow)%h%C(cyan)%d%Creset %s %C(green)- %an, %cr%Creset' --name-status
  #lp = log --oneline -n 20 -p
  #ls = log --stat --abbrev-commit -n 1 # display previous log

  # logをtree表示
  log-graph = log --graph --date=short --pretty=format:'%Cgreen%h %cd %Cblue%cn %Creset%s'
  log-all = log --graph --all --color --pretty='%x09%h %cn%x09%s %Cred%d%Creset'
  loggr = log --graph --date-order --pretty=format:'%Cblue%h %Cgreen%ci %Cred%an %Cblue%m %Creset%s %Cred%d'
  graph = log --graph --decorate --oneline

  # diff関連
  dm = diff master           # masterとのdiff
  dw = diff --color-words    # 単語単位でいろつけてdiff
  dc = diff --cached         # addされているものとのdiff
  ds = diff --staged         # 同上(1.6.1移行)
  d1 = diff HEAD~            # HEADから1つ前とdiff
  d2 = diff HEAD~2           # HEADから2つ前とdiff

  # mergeの際にconflictが起きたファイルを編集
  edit-unmerged = "!f() { git ls-files --unmerged | cut -f2 | sort -u ; }; vim `f`"

  # mergeの際にconflictが起きたファイルをadd
  add-unmerged = "!f() { git ls-files --unmerged | cut -f2 | sort -u ; }; git add `f`"

  # grep関連
  gr = grep
  gn = grep -n

  # cancel
  cancel = !git commit -a -m 'Temporary commit for cancel' && git reset --hard HEAD~

  ignore = !([ ! -e .gitignore ] && touch .gitignore) | echo $1 >> .gitignore
  info = remote show origin

  fixup = commit --amend --no-edit

[merge]
  tool = gvimdiff3

[diff]
  #external = diffvim

[alias]
  pbcopy = !printf "$1" | pbcopy

[tig "bind"]
  generic = g move-first-line
  generic = G move-last-line
  main = C !@git pbcopy %(commit)

[mergetool "gvimdiff3"]
  cmd = gvim -f -d -c \"wincmd J\" \"$MERGED\" \"$LOCAL\" \"$BASE\" \"$REMOTE\"

[mergetool "vimdiff3"]
  cmd = vim -f -d -c \"wincmd J\" \"$MERGED\" \"$LOCAL\" \"$BASE\" \"$REMOTE\"

[http]
  sslVerify = false

[github]
  user = choplin

#[remote "origin"]
  #fetch = +refs/pull/*/head:refs/remotes/origin/pr/*
  #fetch = +refs/pull-requests/*/from:refs/remotes/origin/pr/*

[include]
  path = .gitconfig.local

# vim:ft=gitconfig shiftwidth=2
[difftool "sourcetree"]
	cmd = opendiff \"$LOCAL\" \"$REMOTE\"
	path = 
[mergetool "sourcetree"]
	cmd = /opt/homebrew-cask/Caskroom/sourcetree/2.0.4/SourceTree.app/Contents/Resources/opendiff-w.sh \"$LOCAL\" \"$REMOTE\" -ancestor \"$BASE\" -merge \"$MERGED\"
	trustExitCode = true
[ghi]
	token = !security find-internet-password -a choplin -s github.com -l 'ghi token' -w
[alias]
	stash-pr = !sh -c \"git fetch origin pull-requests/${1}/from:pr/${1}\" -
	github-pr = !sh -c \"git fetch origin pull/${1}/head:pr/${1}\" -
